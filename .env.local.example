# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET="generar-uno-fuerte"

# ── MercadoPago ───────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN="APP_USR-..."
MP_PUBLIC_KEY="APP_USR-..."
# Obtener en: mercadopago.com/developers → Tu app → Webhooks → Secret
MP_WEBHOOK_SECRET=""

# ── Email transaccional (Resend) ──────────────────────────────────────────────
# Obtener en: resend.com → API Keys → Create API Key
RESEND_API_KEY="re_xxxxx"
# Sin dominio propio verificado en Resend, solo podés enviar a tu propio email
# Al verificar distribuidoraosmar.com en resend.com/domains, cambiar a:
# RESEND_FROM="Distribuidora Osmar <notificaciones@distribuidoraosmar.com>"
RESEND_FROM="onboarding@resend.dev"
ADMIN_EMAIL="tu-email@gmail.com"

# ── Cloudinary (imágenes de productos) ────────────────────────────────────────
# Upload usa preset unsigned — NO se necesita API_KEY ni API_SECRET en runtime
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_UPLOAD_PRESET="osmar-products-unsigned"
# Solo necesario para scripts de administración (no para la app en sí)
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# ── Cron ──────────────────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="generar-con-crypto-randomBytes"

# ── URLs ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
