generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model PriceList {
  id                 Int            @id @default(autoincrement())
  name               String         @unique
  description        String?
  discountPercentage Float?         // null = sin descuento / usar precios custom
  isDefault          Boolean        @default(false)
  users              User[]
  productPrices      ProductPrice[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model Salesperson {
  id                 Int                 @id @default(autoincrement())
  name               String
  email              String?             @unique
  phone              String?
  defaultCommission  Float               @default(5)   // % comisión por defecto
  status             String              @default("active") // 'active' | 'inactive'
  clientLinks        ClientSalesperson[]
  assignedUsers      User[]
  orders             Order[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([status])
}

model ClientSalesperson {
  id             Int         @id @default(autoincrement())
  salespersonId  Int
  clientId       Int
  commission     Float?                  // % comisión específica para este cliente (null = usar defaultCommission)
  salesperson    Salesperson @relation(fields: [salespersonId], references: [id], onDelete: Cascade)
  client         User        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())

  @@unique([salespersonId, clientId])
  @@index([clientId])
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String?             @unique              // Opcional para clientes importados de SIPE
  clientCode         String?             @unique              // Número de cliente SIPE
  password           String
  name               String
  phone              String?
  company            String?                                  // Empresa / razón social
  address            String?                                  // Dirección
  city               String?                                  // Ciudad / localidad
  taxId              String?                                  // CUIT / DNI
  role               String              @default("customer")
  status             String              @default("approved") // 'pending' | 'approved' | 'rejected' | 'inactive'
  priceListId        Int?
  salespersonId      Int?                                     // Vendedor asignado
  priceList          PriceList?          @relation(fields: [priceListId], references: [id])
  salesperson        Salesperson?        @relation(fields: [salespersonId], references: [id], onDelete: SetNull)
  salespersonClients ClientSalesperson[]
  orders             Order[]
  cart               Cart?
  lastLogin          DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt

  @@index([clientCode])
  @@index([email])
  @@index([salespersonId])
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  slug     String    @unique
  emoji    String    @default("📦")
  products Product[]
}

model Product {
  id            Int            @id @default(autoincrement())
  code          String         @unique
  name          String
  description   String?
  price         Float
  stock         Int            @default(0)
  active        Boolean        @default(true)
  imageUrl      String?
  bulkUnit      String?
  bulkSize      Int?
  bulkPrice     Float?
  unitPrice     Float?
  categoryId    Int?
  category      Category?      @relation(fields: [categoryId], references: [id])
  cartItems     CartItem[]
  orderItems    OrderItem[]
  productPrices ProductPrice[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([active])
  @@index([categoryId])
  @@index([stock])
  @@index([price])
  @@index([name])
  @@index([active, categoryId])
  @@index([active, stock])
}

model ProductPrice {
  id              Int       @id @default(autoincrement())
  productId       Int
  priceListId     Int
  customPrice     Float?    // override precio unitario
  customBulkPrice Float?    // override precio bulto
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceList       PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([productId, priceListId])
}

model Cart {
  id        Int        @id @default(autoincrement())
  userId    Int?       @unique
  sessionId String?    @unique
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        Int     @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

model Order {
  id               Int          @id @default(autoincrement())

  // ── Identificación SIPE ──────────────────────────────────────
  sipeId           Int?         @unique   // ID original en SIPE
  sipeNumber       String?                // Número de orden SIPE ("00036218")

  // ── Tipo de orden ────────────────────────────────────────────
  // "order"    = Orden de venta (tienda web o SIPE sin factura)
  // "invoiced" = Facturado en AFIP
  orderType        String       @default("order")

  // ── Cliente ──────────────────────────────────────────────────
  userId           Int?
  guestEmail       String?
  guestName        String?
  guestPhone       String?
  clientCode       String?      // Código SIPE del cliente
  clientName       String?      // Nombre del cliente (para órdenes SIPE)

  // ── Estado ───────────────────────────────────────────────────
  // Web: pendiente | procesando | enviado | entregado | cancelado
  // SIPE: delivered | invoiced | cancelled
  status           String       @default("pendiente")

  // ── Factura AFIP ─────────────────────────────────────────────
  invoiceNumber    String?      // "FC A - 12 - 3344 - 15/05/2026"
  invoiceDate      DateTime?
  invoiceType      String?      // "A" | "B" | "C"

  // ── Importes ─────────────────────────────────────────────────
  total            Float        @default(0)  // Total sin IVA (o total general)
  subtotal         Float        @default(0)  // Neto
  tax              Float        @default(0)  // IVA
  totalWithTax     Float        @default(0)  // Total con IVA

  // ── Envío (web) ──────────────────────────────────────────────
  shippingAddress  String?      // Nullable para órdenes SIPE
  shippingCity     String?
  shippingMethod   String       @default("envio")

  // ── Pago ─────────────────────────────────────────────────────
  paymentMethod    String       @default("mercadopago")
  mpPaymentId      String?
  mpStatus         String?

  // ── Vendedor ─────────────────────────────────────────────────
  salespersonId    Int?
  salespersonName  String?      // Nombre original de SIPE
  commissionRate   Float?
  commissionAmount Float?

  // ── Metadata SIPE ────────────────────────────────────────────
  channel          String?      // Canal de venta ("Mayorista", "Local")
  branch           String?      // Sucursal ("Depósito", "Cazón")
  notes            String?
  importedFromSipe Boolean      @default(false)

  // ── Timestamps ───────────────────────────────────────────────
  orderDate        DateTime     @default(now())  // Fecha de la orden original
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user             User?        @relation(fields: [userId], references: [id])
  salesperson      Salesperson? @relation(fields: [salespersonId], references: [id])
  items            OrderItem[]

  @@index([userId])
  @@index([clientCode])
  @@index([salespersonId])
  @@index([orderDate])
  @@index([status])
  @@index([orderType])
  @@index([sipeId])
  @@index([importedFromSipe])
  @@index([createdAt])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  unitPrice Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  entity    String
  entityId  Int?
  userId    Int?
  userName  String?
  details   Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}
